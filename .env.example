# Optional overrides. Copy to .env; never commit .env.
QA_CONFIG_PATH=config/qa-lab.yaml
QA_STAGING_PROFILE_PATH=config/staging-profile.yaml
QA_STAGING_BASE_URL=https://staging-placeholder.invalid
# Bare, comma-separated exact hostnames only. Add asset hosts only after explicit review.
QA_STAGING_ALLOWED_HOSTS=staging-placeholder.invalid,fonts.googleapis.com,fonts.gstatic.com,www.google.com,www.gstatic.com
QA_EXPECTED_TEST_EMAIL=
QA_MANUAL_RESET_CONFIRMED=false
QA_RESET_TOKEN=
QA_ARTIFACT_ROOT=runs
# Safe defaults; exact string true is required to opt in.
QA_ENABLE_RECORDING=false
QA_ENABLE_VOICE=false
QA_ENABLE_REAL_BRAIN=false
QA_BRAIN_GEMINI_API_KEY=
QA_BRAIN_GEMINI_MODEL=gemini-2.5-flash-lite
QA_BRAIN_TIMEOUT_MS=30000
