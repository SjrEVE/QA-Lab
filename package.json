{
  "name": "qa-lab",
  "version": "0.1.0",
  "private": true,
  "description": "Local-first, policy-guarded QA controller foundation.",
  "type": "module",
  "bin": {
    "qa-lab": "dist/cli.js"
  },
  "engines": {
    "node": ">=20"
  },
  "scripts": {
    "build": "tsc -p tsconfig.json",
    "clean": "node -e \"require('node:fs').rmSync('dist',{recursive:true,force:true})\"",
    "lint": "eslint .",
    "test": "node --import tsx --test test/**/*.test.ts",
    "test:coverage": "node --import tsx --test --experimental-test-coverage test/**/*.test.ts",
    "qa:browser:fixture": "tsx scripts/browser-fixture-smoke.ts --fixture-mode",
    "qa:doctor": "tsx src/cli.ts doctor",
    "qa:status": "tsx src/cli.ts status",
    "validate": "npm run lint && npm test && npm run build && npm run qa:doctor"
  },
  "repository": {
    "type": "git",
    "url": "git+https://github.com/SjrEVE/QA-Lab.git"
  },
  "license": "UNLICENSED",
  "dependencies": {
    "dotenv": "^17.2.3",
    "playwright": "^1.61.1",
    "yaml": "^2.8.1",
    "zod": "^4.1.12"
  },
  "devDependencies": {
    "@eslint/js": "^9.39.1",
    "@types/node": "^24.10.1",
    "eslint": "^9.39.1",
    "tsx": "^4.20.6",
    "typescript": "^5.9.3",
    "typescript-eslint": "^8.48.0"
  }
}
