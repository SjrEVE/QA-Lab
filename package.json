{
  "name": "qa-lab",
  "version": "0.1.0",
  "private": true,
  "description": "Local-first, policy-guarded QA controller foundation.",
  "type": "module",
  "bin": {
    "qa-lab": "dist/cli.js"
  },
  "engines": {
    "node": ">=20"
  },
  "scripts": {
    "build": "tsc -p tsconfig.json",
    "clean": "node -e \"require('node:fs').rmSync('dist',{recursive:true,force:true})\"",
    "lint": "eslint .",
    "test": "npm run test:unit && npm run test:browser",
    "test:unit": "node --import tsx --test --test-concurrency=1 test/audio-routing.test.ts test/auth-bootstrap.test.ts test/browser-policy.test.ts test/config.test.ts test/control-center.test.ts test/education-eval.test.ts test/model-arena-cohorts.test.ts test/phase10.test.ts test/recorder.test.ts test/redaction-logger.test.ts test/replay-regression.test.ts test/run-store.test.ts test/security.test.ts test/secret-scan.test.ts test/staging-profile.test.ts test/staging-reset.test.ts test/student-brain.test.ts test/student-contracts.test.ts test/voice-provider.test.ts test/web-scenario.test.ts",
    "test:browser": "node --import tsx --test --test-concurrency=1 test/auth-bootstrap.integration.test.ts test/browser-controller.integration.test.ts test/student-qa.test.ts test/web-qa-failures.test.ts test/web-qa.test.ts",
    "test:coverage": "node --import tsx --test --test-concurrency=1 --experimental-test-coverage test/**/*.test.ts",
    "qa:browser:fixture": "tsx scripts/browser-fixture-smoke.ts --fixture-mode",
    "qa:web:fixture": "tsx scripts/web-fixture-e2e.ts --fixture-mode",
    "qa:student:fixture": "tsx scripts/student-fixture-e2e.ts --fixture-mode",
    "qa:recording:fixture": "tsx scripts/recording-fixture-e2e.ts --fixture-mode",
    "qa:recording:verify": "tsx scripts/verify-recording-capability.ts",
    "qa:voice:fixture": "tsx scripts/voice-fixture-e2e.ts --fixture-mode",
    "qa:evaluation:fixture": "tsx scripts/student-fixture-e2e.ts --fixture-mode",
    "qa:regression:fixture": "tsx scripts/regression-fixture-e2e.ts --fixture-mode",
    "qa:replay:fixture": "tsx scripts/regression-fixture-e2e.ts --fixture-mode",
    "qa:arena:fixture": "tsx scripts/arena-fixture-e2e.ts --fixture-mode",
    "qa:phase10:fixture": "tsx scripts/phase10-fixture-e2e.ts --fixture-mode",
    "qa:safety:fixture": "tsx scripts/phase10-fixture-e2e.ts --fixture-mode",
    "qa:optimizer:fixture": "tsx scripts/phase10-fixture-e2e.ts --fixture-mode",
    "qa:arena": "tsx src/cli.ts arena",
    "qa:compare": "tsx src/cli.ts compare",
    "qa:replay": "tsx src/cli.ts replay",
    "qa:list": "tsx src/cli.ts list",
    "qa:run": "tsx src/cli.ts run",
    "qa:doctor": "tsx src/cli.ts doctor",
    "qa:status": "tsx src/cli.ts status",
    "qa:auth": "tsx src/cli.ts auth",
    "qa:serve": "tsx src/cli.ts serve",
    "qa:reset": "tsx src/cli.ts reset",
    "security:secrets": "tsx scripts/secret-scan.ts",
    "validate": "npm run lint && npm test && npm run build && npm run qa:doctor"
  },
  "repository": {
    "type": "git",
    "url": "git+https://github.com/SjrEVE/QA-Lab.git"
  },
  "license": "UNLICENSED",
  "dependencies": {
    "dotenv": "^17.2.3",
    "playwright": "^1.61.1",
    "yaml": "^2.8.1",
    "zod": "^4.1.12"
  },
  "devDependencies": {
    "@eslint/js": "^9.39.1",
    "@types/node": "^24.10.1",
    "eslint": "^9.39.1",
    "tsx": "^4.20.6",
    "typescript": "^5.9.3",
    "typescript-eslint": "^8.48.0"
  }
}
